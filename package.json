{
  "name": "@endday/search-mcp",
  "version": "1.0.2",
  "description": "MCP server exposing aggregated web search and content extraction tools, backed by a Cloudflare Workers gateway",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "mcp/search-mcp.js",
  "bin": {
    "search-mcp": "./mcp/search-mcp.js"
  },
  "files": [
    "mcp"
  ],
  "scripts": {
    "start": "node mcp/search-mcp.js",
    "test": "node --test test",
    "smoke": "node scripts/smoke-test.js",
    "update:source-authority": "node scripts/update-source-authority.js"
  },
  "keywords": [
    "mcp",
    "search",
    "web-search",
    "cloudflare",
    "cloudflare-workers",
    "self-hosted",
    "ai-agent",
    "openclaw",
    "free-search",
    "privacy",
    "aggregated-search",
    "startpage",
    "mojeek",
    "brave",
    "duckduckgo",
    "bing",
    "qwant",
    "yahoo"
  ],
  "author": "endday",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/endday/search-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "node-html-parser": "^7.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
